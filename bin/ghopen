#!/bin/bash
repo=$(git remote get-url origin | sed 's/git@github.com://;s/.git$//')
branch=$(git branch --show-current)
path=$(git rev-parse --show-prefix | sed 's/\/$//')
# export BROWSER=wslview  # this is for MS Windows WSL, add this to .bashrc
open "https://github.com/$repo/tree/$branch/$path"

