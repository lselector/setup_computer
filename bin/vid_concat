#!/bin/bash

# vid_concat - Concatenate videos and/or images into one video
# Usage: vid_concat file1.mp4 file2.mp4 [file3.mp4 ...]
#        vid_concat -j config.json
# Output: <first_file>_concat.mp4
#
# Supports video files (mp4, mov, avi, mkv, etc.) and image files
# (avif, heic, jpeg, jpg, png, webp, gif, bmp).
# Images are converted to 4-second video clips.
# All inputs are scaled/padded to 1280x720 (black padding, preserving aspect ratio).
#
# JSON format for -j option:
# [
#     ["Title for Video 1", "video1.mp4"],
#     ["", "video2.mp4"],
#     ["Title for Image", "image1.jpg"],
#     ["", "image2.png"],
#     ["Title for Video 3", "video3.mp4"]
# ]
# Each non-empty title becomes a 4-second title card (black bg, white text)
# prepended before its video/image. Use "" for no title card.
# Long titles are automatically word-wrapped.

TITLE_DURATION=4
TITLE_FONTSIZE=48
TITLE_MAX_WIDTH_RATIO=0.85  # text uses at most 85% of video width
IMAGE_DURATION=4             # how long each image is displayed (seconds)
WIDTH=1280
HEIGHT=720

# ---- Helper: check if a file is an image by extension ----
is_image_file() {
    local f="$1"
    local ext="${f##*.}"
    ext=$(echo "$ext" | tr '[:upper:]' '[:lower:]')
    case "$ext" in
        avif|heic|jpeg|jpg|png|webp|gif|bmp) return 0 ;;
        *) return 1 ;;
    esac
}

# ---- Parse arguments ----
JSON_FILE=""
if [ "$1" = "-j" ]; then
    if [ -z "$2" ]; then
        echo "Error: -j requires a JSON file argument"
        exit 1
    fi
    JSON_FILE="$2"
    if [ ! -f "$JSON_FILE" ]; then
        echo "Error: JSON file '$JSON_FILE' not found"
        exit 1
    fi
    # Check that jq is available
    if ! command -v jq &>/dev/null; then
        echo "Error: 'jq' is required for JSON parsing but not found. Install with: brew install jq"
        exit 1
    fi
fi

# ---- Cleanup function for temp files ----
TEMP_FILES=()
cleanup() {
    for f in "${TEMP_FILES[@]}"; do
        rm -f "$f"
    done
}
trap cleanup EXIT

# ---- Function: word-wrap text to fit within max width ----
wrap_title_text() {
    local text="$1"
    local max_chars

    # Approximate character width: fontsize * 0.55 (Helvetica average)
    local char_width
    char_width=$(echo "scale=0; ${TITLE_FONTSIZE} * 55 / 100" | bc)
    local max_pixel_width
    max_pixel_width=$(echo "scale=0; ${WIDTH} * ${TITLE_MAX_WIDTH_RATIO} / 1" | bc)
    max_chars=$(echo "scale=0; ${max_pixel_width} / ${char_width}" | bc)

    if [ "$max_chars" -lt 10 ]; then
        max_chars=10
    fi

    # Word-wrap using fold to break at word boundaries
    echo "$text" | fold -s -w "$max_chars"
}

# ---- Detect whether ffmpeg supports the drawtext filter ----
HAS_DRAWTEXT=false
if ffmpeg -filters 2>&1 | grep -q "drawtext"; then
    HAS_DRAWTEXT=true
fi

# ---- Function: generate a title card image using ImageMagick or Python ----
generate_title_card_image() {
    local title_text="$1"
    local outpng="$2"

    # Word-wrap the title text
    local wrapped_text
    wrapped_text=$(wrap_title_text "$title_text")

    # Replace newlines with literal \n for ImageMagick
    local magick_text
    magick_text=$(echo "$wrapped_text" | sed ':a;N;$!ba;s/\n/\\n/g')

    if command -v magick &>/dev/null; then
        magick -size "${WIDTH}x${HEIGHT}" xc:black \
            -gravity center -fill white -pointsize "${TITLE_FONTSIZE}" \
            -font Helvetica -annotate +0+0 "$magick_text" \
            "$outpng" 2>&1
        if [ $? -eq 0 ]; then
            return 0
        fi
    fi

    if command -v convert &>/dev/null; then
        convert -size "${WIDTH}x${HEIGHT}" xc:black \
            -gravity center -fill white -pointsize "${TITLE_FONTSIZE}" \
            -font Helvetica -annotate +0+0 "$magick_text" \
            "$outpng" 2>&1
        if [ $? -eq 0 ]; then
            return 0
        fi
    fi

    # Fallback: use Python with Pillow
    if command -v python3 &>/dev/null; then
        python3 - "$title_text" "$outpng" "${WIDTH}" "${HEIGHT}" "${TITLE_FONTSIZE}" "${TITLE_MAX_WIDTH_RATIO}" <<'PYEOF'
import sys, textwrap
from PIL import Image, ImageDraw, ImageFont

title_text = sys.argv[1]
outpng = sys.argv[2]
W, H = int(sys.argv[3]), int(sys.argv[4])
fontsize = int(sys.argv[5])
max_width_ratio = float(sys.argv[6])

img = Image.new('RGB', (W, H), 'black')
draw = ImageDraw.Draw(img)

font = None
for fpath in ['/System/Library/Fonts/Helvetica.ttc',
              '/System/Library/Fonts/SFNSText.ttf',
              '/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf']:
    try:
        font = ImageFont.truetype(fpath, fontsize)
        break
    except:
        pass
if font is None:
    font = ImageFont.load_default()

max_chars = max(10, int(W * max_width_ratio / (fontsize * 0.55)))
wrapped = textwrap.fill(title_text, width=max_chars)
lines = wrapped.split('\n')

line_height = fontsize + 12
total_height = len(lines) * line_height
y_start = (H - total_height) // 2

for i, line in enumerate(lines):
    bbox = draw.textbbox((0, 0), line, font=font)
    tw = bbox[2] - bbox[0]
    x = (W - tw) // 2
    y = y_start + i * line_height
    draw.text((x, y), line, fill='white', font=font)

img.save(outpng)
PYEOF
        if [ $? -eq 0 ]; then
            return 0
        fi
    fi

    echo "Error: Cannot generate title card image. Install ImageMagick (brew install imagemagick) or Python Pillow (pip install Pillow)."
    return 1
}

# ---- Function: generate a title card video ----
generate_title_card() {
    local title_text="$1"
    local outfile="$2"

    if [ "$HAS_DRAWTEXT" = true ]; then
        # Use ffmpeg drawtext filter directly
        local wrapped_text
        wrapped_text=$(wrap_title_text "$title_text")

        local line_count
        line_count=$(echo "$wrapped_text" | wc -l | tr -d ' ')
        local line_height=$((TITLE_FONTSIZE + 12))
        local total_text_height=$((line_count * line_height))
        local y_start=$(( (HEIGHT - total_text_height) / 2 ))

        local vf_filter=""
        local line_num=0
        while IFS= read -r line; do
            local escaped_line
            escaped_line=$(echo "$line" | sed "s/\\\\/\\\\\\\\/g; s/:/\\\\:/g; s/'/\\\\'/g; s/\[/\\\\[/g; s/\]/\\\\]/g; s/;/\\\\;/g")

            local y_pos=$((y_start + line_num * line_height))

            if [ -n "$vf_filter" ]; then
                vf_filter="${vf_filter},"
            fi
            vf_filter="${vf_filter}drawtext=text='${escaped_line}':fontsize=${TITLE_FONTSIZE}:fontcolor=white:x=(w-text_w)/2:y=${y_pos}:font=Helvetica"

            line_num=$((line_num + 1))
        done <<< "$wrapped_text"

        ffmpeg -y -f lavfi -i "color=c=black:s=${WIDTH}x${HEIGHT}:d=${TITLE_DURATION}:r=30" \
            -f lavfi -i "anullsrc=channel_layout=stereo:sample_rate=44100" \
            -t "$TITLE_DURATION" \
            -vf "${vf_filter}" \
            -c:v libx264 -crf 18 -preset medium \
            -c:a aac -b:a 192k \
            -shortest \
            "$outfile" 2>&1

        if [ $? -ne 0 ]; then
            echo "Error: Failed to generate title card for: $title_text"
            exit 1
        fi
    else
        # Fallback: generate a title card PNG, then convert to video
        local title_png="${outfile%.mp4}.png"
        generate_title_card_image "$title_text" "$title_png"
        if [ $? -ne 0 ]; then
            echo "Error: Failed to generate title card for: $title_text"
            exit 1
        fi
        TEMP_FILES+=("$title_png")

        ffmpeg -y -loop 1 -i "$title_png" \
            -f lavfi -i "anullsrc=channel_layout=stereo:sample_rate=44100" \
            -t "$TITLE_DURATION" \
            -vf "scale=${WIDTH}:${HEIGHT},setsar=1" \
            -r 30 \
            -c:v libx264 -crf 18 -preset medium \
            -c:a aac -b:a 192k \
            -shortest \
            "$outfile" 2>&1

        if [ $? -ne 0 ]; then
            echo "Error: Failed to generate title card video for: $title_text"
            exit 1
        fi
    fi
}

# ---- Function: convert an image to a video clip ----
image_to_video() {
    local imgfile="$1"
    local outfile="$2"

    echo "Converting image to ${IMAGE_DURATION}s video: $imgfile"

    ffmpeg -y -loop 1 -i "$imgfile" \
        -f lavfi -i "anullsrc=channel_layout=stereo:sample_rate=44100" \
        -t "$IMAGE_DURATION" \
        -vf "scale=${WIDTH}:${HEIGHT}:force_original_aspect_ratio=decrease,pad=${WIDTH}:${HEIGHT}:(${WIDTH}-iw)/2:(${HEIGHT}-ih)/2:black,setsar=1" \
        -r 30 \
        -c:v libx264 -crf 18 -preset medium \
        -c:a aac -b:a 192k \
        -shortest \
        "$outfile" 2>&1

    if [ $? -ne 0 ]; then
        echo "Error: Failed to convert image to video: $imgfile"
        exit 1
    fi
}

# ---- Build the list of video files to concatenate ----
declare -a ALL_FILES=()

if [ -n "$JSON_FILE" ]; then
    # Parse JSON file
    entry_count=$(jq 'length' "$JSON_FILE")
    if [ "$entry_count" -lt 1 ]; then
        echo "Error: JSON file contains no entries"
        exit 1
    fi

    echo "Reading JSON file: $JSON_FILE ($entry_count entries)"
    echo ""

    for ((i=0; i<entry_count; i++)); do
        title=$(jq -r ".[$i][0]" "$JSON_FILE")
        media=$(jq -r ".[$i][1]" "$JSON_FILE")

        if [ ! -f "$media" ]; then
            echo "Error: File '$media' not found (entry $((i+1)))"
            exit 1
        fi

        # If title is non-empty, generate a title card
        if [ -n "$title" ]; then
            tmpfile="/tmp/vid_concat_title_${i}_$$.mp4"
            echo "Generating title card: \"$title\""
            generate_title_card "$title" "$tmpfile"
            TEMP_FILES+=("$tmpfile")
            ALL_FILES+=("$tmpfile")
        fi

        # If it's an image, convert to video clip
        if is_image_file "$media"; then
            img_tmpfile="/tmp/vid_concat_img_${i}_$$.mp4"
            image_to_video "$media" "$img_tmpfile"
            TEMP_FILES+=("$img_tmpfile")
            ALL_FILES+=("$img_tmpfile")
        else
            ALL_FILES+=("$media")
        fi
    done

    # Derive output filename from first media file in JSON
    first_media=$(jq -r '.[0][1]' "$JSON_FILE")
else
    # Original mode: positional arguments
    if [ "$#" -lt 2 ]; then
        echo "vid_concat - Concatenate videos and/or images into one video"
        echo ""
        echo "Usage: vid_concat <file1> <file2> [file3 ...]"
        echo "       vid_concat -j <config.json>"
        echo ""
        echo "Examples:"
        echo "  vid_concat clip1.mp4 clip2.mp4 clip3.mp4"
        echo "  vid_concat clip1.mp4 photo.jpg clip2.mp4"
        echo "  vid_concat -j config.json"
        echo ""
        echo "Concatenates two or more video/image files into one ${WIDTH}x${HEIGHT} video."
        echo "All inputs are scaled and padded to ${WIDTH}x${HEIGHT} (black padding,"
        echo "preserving original aspect ratio)."
        echo ""
        echo "Supported video formats: mp4, mov, avi, mkv, and other ffmpeg-supported formats"
        echo "Supported image formats: avif, heic, jpeg, jpg, png, webp, gif, bmp"
        echo "Images are displayed for ${IMAGE_DURATION} seconds each."
        echo ""
        echo "Output: <first_file>_concat.mp4"
        echo ""
        echo "JSON mode (-j):"
        echo "  Provide a JSON file with optional titles and media paths:"
        echo '  ['
        echo '      ["Title for Video 1", "video1.mp4"],'
        echo '      ["", "video2.mp4"],'
        echo '      ["Title for Image", "image1.jpg"],'
        echo '      ["", "image2.png"],'
        echo '      ["Title for Video 3", "video3.mp4"]'
        echo '  ]'
        echo ""
        echo "  Each non-empty title becomes a ${TITLE_DURATION}-second title card"
        echo "  (black background, white centered text) prepended before its media."
        echo '  Use "" (empty string) for no title card.'
        echo "  Long titles are automatically word-wrapped."
        exit 1
    fi

    # Check that all input files exist
    for f in "$@"; do
        if [ ! -f "$f" ]; then
            echo "Error: File '$f' not found"
            exit 1
        fi
    done

    # Process positional arguments — convert images to video clips
    img_idx=0
    for f in "$@"; do
        if is_image_file "$f"; then
            img_tmpfile="/tmp/vid_concat_img_arg_${img_idx}_$$.mp4"
            image_to_video "$f" "$img_tmpfile"
            TEMP_FILES+=("$img_tmpfile")
            ALL_FILES+=("$img_tmpfile")
            img_idx=$((img_idx + 1))
        else
            ALL_FILES+=("$f")
        fi
    done

    first_media="$1"
fi

# Build output filename from the first media file
dir=$(dirname "$first_media")
filename=$(basename "$first_media")
name="${filename%.*}"
output_file="${dir}/${name}_concat.mp4"

n=${#ALL_FILES[@]}

# Print input info
echo ""
echo "========== INPUTS =========="
total_input_bytes=0
for f in "${ALL_FILES[@]}"; do
    width_val=$(ffprobe -v error -select_streams v:0 -show_entries stream=width -of csv=s=x:p=0 "$f")
    height_val=$(ffprobe -v error -select_streams v:0 -show_entries stream=height -of csv=s=x:p=0 "$f")
    size_bytes=$(stat -f%z "$f" 2>/dev/null || stat -c%s "$f" 2>/dev/null)
    size_mb=$(echo "scale=2; $size_bytes / 1048576" | bc)
    total_input_bytes=$((total_input_bytes + size_bytes))
    echo "  $f  (${width_val}x${height_val}, ${size_mb} MB)"
done
total_input_mb=$(echo "scale=2; $total_input_bytes / 1048576" | bc)
echo "Total input size: ${total_input_mb} MB"
echo "============================"
echo ""

# Build ffmpeg filter to normalize all inputs to 1280x720 and concatenate
inputs=""
filter=""
idx=0
for f in "${ALL_FILES[@]}"; do
    inputs="$inputs -i \"$f\""
    filter="${filter}[${idx}:v]scale=${WIDTH}:${HEIGHT}:force_original_aspect_ratio=decrease,pad=${WIDTH}:${HEIGHT}:(${WIDTH}-iw)/2:(${HEIGHT}-ih)/2:black,setsar=1[v${idx}];"
    idx=$((idx + 1))
done

# Build concat part of the filter
concat_inputs=""
for ((i=0; i<n; i++)); do
    concat_inputs="${concat_inputs}[v${i}][${i}:a]"
done
filter="${filter}${concat_inputs}concat=n=${n}:v=1:a=1[outv][outa]"

echo "Concatenating ${n} clips into ${WIDTH}x${HEIGHT} output..."
echo ""

# Run ffmpeg
eval ffmpeg $inputs -filter_complex "\"${filter}\"" -map '"[outv]"' -map '"[outa]"' -c:v libx264 -crf 18 -preset medium -c:a aac -b:a 192k "\"${output_file}\""

if [ $? -eq 0 ]; then
    # Get output video info
    output_resolution=$(ffprobe -v error -select_streams v:0 -show_entries stream=width,height -of csv=s=x:p=0 "$output_file")
    output_size_bytes=$(stat -f%z "$output_file" 2>/dev/null || stat -c%s "$output_file" 2>/dev/null)
    output_size_mb=$(echo "scale=2; $output_size_bytes / 1048576" | bc)

    echo ""
    echo "========== SUMMARY =========="
    echo "Inputs:     ${n} clips (${total_input_mb} MB total)"
    echo ""
    echo "Output:     $output_file"
    echo "Resolution: $output_resolution"
    echo "Size:       ${output_size_mb} MB"
    echo "============================="
    echo ""
    echo "Done!"
else
    echo "Error: ffmpeg failed"
    exit 1
fi
