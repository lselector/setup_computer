#!/usr/bin/env python3
"""
Convert a Markdown file to PDF using weasyprint.

Usage:
    md2pdf input.md
    md2pdf input.md output.pdf
    md2pdf ~/notes/today.md ~/Desktop/today.pdf

If the output path is omitted, the PDF is written
next to the input file with a .pdf extension.

Created: 2026-04-19
Last updated: 2026-04-19
"""

import sys
from pathlib import Path

import markdown
from weasyprint import HTML, CSS


DEFAULT_CSS = """
@page { size: Letter; margin: 0.9in; }
body {
    font-family: -apple-system, "Helvetica Neue",
                 Helvetica, Arial, sans-serif;
    font-size: 11pt;
    line-height: 1.5;
    color: #222;
}
h1, h2, h3, h4 { color: #111; margin-top: 1.1em; }
h1 { border-bottom: 1px solid #ddd; padding-bottom: 4px; }
h2 { border-bottom: 1px solid #eee; padding-bottom: 3px; }
a { color: #0a58ca; text-decoration: none; }
code {
    background: #f4f4f4;
    padding: 2px 4px;
    border-radius: 3px;
    font-family: "Menlo", "Courier New", monospace;
    font-size: 10pt;
}
pre {
    background: #f6f8fa;
    padding: 10px 12px;
    border-radius: 5px;
    overflow-x: auto;
    font-size: 10pt;
}
pre code { background: none; padding: 0; }
table {
    border-collapse: collapse;
    margin: 1em 0;
    width: 100%;
}
th, td {
    border: 1px solid #ccc;
    padding: 6px 10px;
    text-align: left;
}
th { background: #f2f2f2; }
blockquote {
    border-left: 4px solid #ccc;
    padding: 0 12px;
    color: #555;
    margin: 1em 0;
}
img { max-width: 100%; }
hr { border: 0; border-top: 1px solid #ddd; }
"""


# --------------------------------------------------------------
def md_to_html(md_text):
    """Convert markdown text to an HTML document."""
    extensions = [
        "fenced_code",
        "tables",
        "codehilite",
        "toc",
        "sane_lists",
    ]
    body = markdown.markdown(md_text, extensions=extensions)
    return (
        "<!doctype html><html><head>"
        "<meta charset='utf-8'></head>"
        f"<body>{body}</body></html>"
    )


# --------------------------------------------------------------
def convert(md_path, pdf_path):
    """Convert a markdown file to a PDF file."""
    md_text = md_path.read_text(encoding="utf-8")
    html_str = md_to_html(md_text)
    base = str(md_path.parent)
    HTML(string=html_str, base_url=base).write_pdf(
        str(pdf_path),
        stylesheets=[CSS(string=DEFAULT_CSS)],
    )
    print(f"Wrote {pdf_path}")


# --------------------------------------------------------------
def resolve_paths(args):
    """Determine input and output paths from argv."""
    if len(args) < 1 or len(args) > 2:
        print("Usage: md2pdf input.md [output.pdf]")
        sys.exit(1)
    md_path = Path(args[0]).expanduser().resolve()
    if not md_path.is_file():
        print(f"Not found: {md_path}")
        sys.exit(1)
    if len(args) == 2:
        pdf_path = Path(args[1]).expanduser().resolve()
    else:
        pdf_path = md_path.with_suffix(".pdf")
    return md_path, pdf_path


# --------------------------------------------------------------
def main():
    """Parse arguments and run the conversion."""
    md_path, pdf_path = resolve_paths(sys.argv[1:])
    convert(md_path, pdf_path)


# --------------------------------------------------------------
if __name__ == "__main__":
    main()
